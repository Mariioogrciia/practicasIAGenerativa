# Copia este archivo a .env y completa los valores reales
AZURE_FOUNDRY_PROJECT_ENDPOINT="https://<tu-recurso>.services.ai.azure.com/api/projects/<tu-proyecto>"
AZURE_FOUNDRY_OPENAI_BASE_URL="https://<tu-recurso>.services.ai.azure.com/api/projects/<tu-proyecto>/openai/v1/"
AZURE_FOUNDRY_MODELS_ENDPOINT="https://<tu-recurso>.services.ai.azure.com/models"

AZURE_OPENAI_CHAT_DEPLOYMENT="gpt-4o-mini"
AZURE_OPENAI_REASONING_DEPLOYMENT="gpt-5-mini"
AZURE_PHI_MULTIMODAL_DEPLOYMENT="Phi-4-multimodal-instruct"

DEFAULT_IMAGE_URL="https://<tu-imagen-publica>.jpg"
